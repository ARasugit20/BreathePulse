# Backend
DATABASE_URL=postgresql+asyncpg://breathepulse:breathepulse@localhost:5432/breathepulse
DATABASE_URL_SYNC=postgresql://breathepulse:breathepulse@localhost:5432/breathepulse
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Supabase Auth (optional — dev mode works without these)
